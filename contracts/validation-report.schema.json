{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ValidationReport",
  "type": "object",
  "required": ["passed", "issues"],
  "properties": {
    "passed": {
      "type": "boolean"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "severity", "message"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["lint", "typecheck", "rule", "e2e", "visual", "review"]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "message": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        }
      }
    }
  }
}
