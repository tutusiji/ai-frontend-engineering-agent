{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PagePlan",
  "type": "object",
  "required": ["targetProfile", "pages"],
  "properties": {
    "targetProfile": {
      "type": "string"
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pageType", "routeMode"],
        "properties": {
          "name": { "type": "string" },
          "pageType": {
            "type": "string",
            "enum": ["list", "form", "detail", "dashboard", "modal", "drawer", "tab", "wizard"]
          },
          "routeMode": {
            "type": "string",
            "enum": ["menu-route", "child-route", "modal", "drawer", "tab-page", "miniapp-page", "standalone"]
          },
          "reusedComponents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dangerActions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
