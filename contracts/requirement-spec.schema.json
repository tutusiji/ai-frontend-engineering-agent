{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RequirementSpec",
  "type": "object",
  "required": ["featureName", "pages", "entities"],
  "properties": {
    "featureName": {
      "type": "string"
    },
    "businessGoal": {
      "type": "string"
    },
    "pages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/page"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["name", "goal"],
      "properties": {
        "name": { "type": "string" },
        "goal": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "entity": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      }
    }
  }
}
