{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TargetProfileSelection",
  "type": "object",
  "required": ["profileId", "platform", "framework"],
  "properties": {
    "profileId": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "enum": ["admin-web", "pc-spa", "h5-spa", "miniapp"]
    },
    "framework": {
      "type": "string",
      "enum": ["vue3", "react", "native-miniapp", "unknown"]
    },
    "uiLibrary": {
      "type": "string"
    },
    "routingMode": {
      "type": "string",
      "enum": ["vue-router", "react-router", "miniapp-pages", "custom", "none"]
    },
    "styling": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
