{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestPlan",
  "type": "object",
  "required": ["pageName", "scenarios"],
  "properties": {
    "pageName": { "type": "string" },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["unit", "e2e", "visual", "rule"]
          },
          "priority": {
            "type": "string",
            "enum": ["p0", "p1", "p2"]
          }
        }
      }
    }
  }
}
